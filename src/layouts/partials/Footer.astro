---
import ImageMod from "@/components/ImageMod.astro";
import menu from "@/config/menu.json";
import config from "@/config/config.json";

const { footer }: { footer: any } = menu;
---

<footer class="section">
  <div class="container">
    <div class="row max-md:gy-5 gx-5 justify-between">
      <div class="col-12 md:col-5" data-aos="fade-right-sm">
        <ImageMod class="mb-10 w-40" src="/images/logo.svg" alt="Logo" width={0} height={0} />
        <p class="mb-6">Klare Einstiege fuer Leistungen, Fachartikel, IT-News und Kontakt.</p>
        <p class="mb-6">{config.params.copyright}</p>
        <div class="flex flex-wrap items-center gap-3 text-sm">
          <a href="https://www.linkedin.com/in/attilakrick/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/attkri" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="mailto:info@attilakrick.com">info@attilakrick.com</a>
        </div>
      </div>
      <div class="col-12 md:col-6">
        <div class="justify-between row g-4">
          {
            footer.map((item: { items: any[] }, i: number) => (
              <div class="col-6">
                <ul class="flex flex-col gap-4" data-aos="fade-right-sm" data-aos-delay={50 + i * 100}>
                  {item.items.map((item: any) => (
                    <li class="text-[14px] leading-[20px]">
                      <a href={item.url}>{item.name}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>
