---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { markdownify } from "@/lib/utils/textConverter";
import CallToAction from "@/partials/CallToAction.astro";
import { Icon } from "astro-icon/components";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import BlogCard from "@/components/BlogCard.astro";
import ServiceSlider from "@/components/homepage/ServiceSlider.astro";

const homepage = await getListPage("homepage", "-index");
const { banner, service, feature, about } = homepage.data;

const postIndex = await getListPage("articles", "-index");
const newsIndex = await getListPage("news", "-index");
const { homepage_title, homepage_description } = postIndex.data;
const { homepage_title: news_homepage_title, homepage_description: news_homepage_description } = newsIndex.data;
const posts = (await getSinglePage("articles"))
  .sort((a, b) => new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime())
  .slice(0, 3);
const latestNews = (await getSinglePage("news")).sort(
  (a, b) => new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime()
)[0];
const latestNewsImage = latestNews?.data.image ?? "/images/legacy/site/news-default.png";
---

<Base>
  <!-- Banner -->
  <section class="section pt-[75px] pb-0 bg-light">
    <div class="container relative">
      <div class="items-center row gy-5 gx-4 xl:gx-5">
        <div class="lg:col-7">
          <h1
            class="max-w-4xl"
            data-aos="fade-up-sm"
            data-aos-delay="50"
            set:html={markdownify(banner.title)}
          />

          <p
            class="max-w-2xl pt-6 pb-8"
            data-aos="fade-up-sm"
            data-aos-delay="100"
            set:html={markdownify(banner.content)}
          />

          <div class="flex flex-wrap gap-3" data-aos="fade-up-sm" data-aos-delay="150">
            {banner.button && (
              <a class="btn btn-primary" href={banner.button.link}>
                {banner.button.label}
              </a>
            )}
            <a class="btn btn-outline-primary" href="/kontakt">Projektanfrage starten</a>
          </div>

          <div class="flex flex-wrap gap-3 pt-6" data-aos="fade-up-sm" data-aos-delay="200">
            <a class="btn btn-outline-primary btn-sm" href="/leistung#powershell">PowerShell</a>
            <a class="btn btn-outline-primary btn-sm" href="/leistung#sql-server">SQL Server</a>
            <a class="btn btn-outline-primary btn-sm" href="/leistung#ki-agenten">KI-Agenten</a>
            <a class="btn btn-outline-primary btn-sm" href="/artikel">Fachartikel</a>
            <a class="btn btn-outline-primary btn-sm" href="/news">IT-News</a>
          </div>
        </div>

        <div class="lg:col-5">
          <div class="grid gap-4 sm:grid-cols-2" data-aos="fade-up-sm" data-aos-delay="100">
            <div class="p-6 border border-border rounded-xl bg-white/70">
              <p class="text-sm text-text-light uppercase tracking-[0.16em] pb-3">Erfahrung</p>
              <p class="h2 pb-2">30+</p>
              <p>Jahre IT-Praxis zwischen Entwicklung, Betrieb und Architektur.</p>
            </div>
            <div class="p-6 border border-border rounded-xl bg-white/70">
              <p class="text-sm text-text-light uppercase tracking-[0.16em] pb-3">Training</p>
              <p class="h2 pb-2">1.500+</p>
              <p>Schulungstage fuer Unternehmen, Mittelstand und Behoerden.</p>
            </div>
          </div>

          <div class="mt-4 p-6 border border-border rounded-xl bg-white/70" data-aos="fade-up-sm" data-aos-delay="180">
            <div class="flex items-center gap-4 pb-4 border-b border-border">
              <div class="w-16 h-16 overflow-hidden rounded-full border border-border bg-light shrink-0">
                <ImageMod
                  src={about.image}
                  width={64}
                  height={64}
                  alt="Attila Krick"
                  format="webp"
                  class="w-full h-full object-cover"
                />
              </div>
              <div>
                <p class="font-semibold text-xl">Attila Krick</p>
                <p class="text-text-light">Beratung, Umsetzung und Training fuer PowerShell, SQL Server und KI-Agenten.</p>
              </div>
            </div>
            <p class="pt-4">Kein Schaufenstertext, sondern klare Einordnung, belastbare Umsetzung und Wissenstransfer, der im Team bleibt.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Banner -->

  <!-- service -->
  <section class="pb-0 section">
    <div class="container">
      <h2
        class="pb-8"
        data-aos="fade-right-sm"
        set:html={markdownify(service.title)}
      />
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          service.services.map((s, i: number) => (
            <div
              class="p-8 border border-border rounded-xl"
              data-aos="fade-right-sm"
              data-aos-delay={i * 100}
            >
              <Icon name={s.image} class="w-16 h-16 mb-10 lg:mb-24" />
              <h3 class="mb-4 text-2xl" set:html={markdownify(s.title)} />
              <p class="mb-4" set:html={markdownify(s.content)} />
              {s.button.enable && (
                <a
                  href={s.button.link}
                  class="flex items-center gap-1 transition duration-300 text-secondary hover:opacity-80"
                >
                  Mehr erfahren <span class="sr-only">Details</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-right"
                  >
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M5 12l14 0" />
                    <path d="M13 18l6 -6" />
                    <path d="M13 6l6 6" />
                  </svg>
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>
  <!-- service -->

  <!-- feature -->
  <section class="section">
    <div class="container">
      <div class="justify-center mb-10 row xl:mb-14">
        <div class="lg:col-8">
          <h2
            class="text-center"
            data-aos="fade-up-sm"
            set:html={markdownify(feature.title)}
          />
        </div>
        <div class="lg:col-6">
          <p
            class="text-center"
            data-aos="fade-up-sm"
            set:html={markdownify(feature.content)}
          />
        </div>
      </div>
      <div
        class="flex flex-col-reverse gap-10 md:flex-row justify-center lg:justify-between md:items-stretch"
      >
        <ServiceSlider feature={feature.features} />
      </div>
    </div>
  </section>
  <!-- feature -->

  <!-- news -->
  {
    latestNews && (
      <section class="section pb-0">
        <div class="container">
          <div class="flex flex-col gap-10">
            <div class="justify-center row">
              <div class="lg:col-8">
                <h2 class="pb-4 text-center" data-aos="fade-up-sm" set:html={markdownify(news_homepage_title!)} />
                <p class="text-center" data-aos="fade-up-sm" set:html={markdownify(news_homepage_description!)} />
              </div>
            </div>

            <div class="p-6 md:p-8 border border-border rounded-xl bg-light/60" data-aos="fade-up-sm">
              <div class="items-center row gy-5 gx-4 xl:gx-5">
                <div class="lg:col-5">
                  <div class="overflow-hidden rounded-xl border border-border bg-white">
                    <ImageMod
                      src={latestNewsImage}
                      width={640}
                      height={420}
                      alt={latestNews.data.title}
                      format="webp"
                      class="w-full aspect-[16/10] object-cover"
                    />
                  </div>
                </div>
                <div class="lg:col-7">
                  <p class="text-sm text-text-light uppercase tracking-[0.16em] pb-3">
                    {dateFormat(latestNews.data.date!)} · IT-News
                  </p>
                  <h3 class="h3 pb-4">
                    <a href={`/news/${latestNews.id}`}>{latestNews.data.title}</a>
                  </h3>
                  <p class="pb-6" set:html={markdownify(latestNews.data.description)} />
                  <div class="flex flex-wrap gap-3">
                    <a class="btn btn-primary" href={`/news/${latestNews.id}`}>Aktuelle News lesen</a>
                    <a class="btn btn-outline-primary" href="/news">Alle IT-News</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }
  <!-- news -->

  <!-- profile -->
  <section class="section bg-primary">
    <div class="container text-white">
      <div class="items-center justify-center row md:justify-between gy-5 gx-4 xl:gx-5">
        <div class="col-12 md:col-5">
          <div class="flex flex-col gap-6">
            <h2 class="text-white" data-aos="fade-up-sm" set:html={markdownify(about.title)} />
            <p class="text-light/80" data-aos="fade-up-sm" set:html={markdownify(about.content)} />
            <p class="text-light/80" data-aos="fade-up-sm" set:html={markdownify(about.content_2)} />
            {about.button.enable && (
              <div class="inline-block" data-aos="fade-up-sm">
                <a href={about.button.link} class="btn btn-outline-secondary" set:html={about.button.label} />
              </div>
            )}
          </div>
        </div>
        <div class="col-12 md:col-6">
          <div class="row g-4">
            <div class="sm:col-4" data-aos="fade-up-sm">
              <div class="h-full p-6 border border-border/20 rounded-xl bg-white/5">
                <p class="text-sm uppercase tracking-[0.16em] text-light/60 pb-3">Erfahrung</p>
                <p class="h3 text-white pb-2">30+</p>
                <p class="text-light/80">Jahre IT-Praxis zwischen Entwicklung, Betrieb und Architektur.</p>
              </div>
            </div>
            <div class="sm:col-4" data-aos="fade-up-sm" data-aos-delay="100">
              <div class="h-full p-6 border border-border/20 rounded-xl bg-white/5">
                <p class="text-sm uppercase tracking-[0.16em] text-light/60 pb-3">Training</p>
                <p class="h3 text-white pb-2">1.500+</p>
                <p class="text-light/80">Schulungstage mit Fokus auf reale Arbeit statt Schaufensterfolien.</p>
              </div>
            </div>
            <div class="sm:col-4" data-aos="fade-up-sm" data-aos-delay="200">
              <div class="h-full p-6 border border-border/20 rounded-xl bg-white/5">
                <p class="text-sm uppercase tracking-[0.16em] text-light/60 pb-3">Einsatz</p>
                <p class="h3 text-white pb-2">EU</p>
                <p class="text-light/80">Remote und vor Ort fuer Unternehmen, Mittelstand und Behoerden.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- profile -->

  <!-- blog -->
  <section class="pb-0 section">
    <div class="container">
      <div class="flex flex-col gap-14">
        <div class="justify-center row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center"
              data-aos="fade-up-sm"
              set:html={markdownify(homepage_title!)}
            />
            <p
              class="text-center"
              data-aos="fade-up-sm"
              set:html={markdownify(homepage_description!)}
            />
          </div>
        </div>
        <div class="row g-4">
          {
            posts.map((post, i: number) => (
              <div
                class="relative sm:col-6 lg:col-4 group"
                data-aos="fade-up-sm"
                data-aos-delay={i * 100}
              >
                <BlogCard post={post} basePath="artikel" />
              </div>
            ))
          }
        </div>
        <div class="inline-block text-center">
          <a class="btn btn-outline-primary" href="/artikel">
            Alle Artikel ansehen
          </a>
        </div>
      </div>
    </div>
  </section>
  <!-- blog -->

  <CallToAction />
</Base>
