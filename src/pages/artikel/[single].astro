---
import Base from "@/layouts/Base.astro";
import PostSingle from "@/layouts/PostSingle.astro";
import { getSinglePage } from "@/lib/contentParser.astro";

export async function getStaticPaths() {
  const posts = await getSinglePage("articles");

  return posts.map((post) => ({
    params: {
      single: post.id,
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, meta_title, description, image, date, author } = post.data;
---

<Base title={title} meta_title={meta_title} description={description} image={image} schema_type="article" date={date} author={author}>
  <PostSingle post={post} />
</Base>
