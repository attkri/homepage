---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { render } from "astro:content";

const glossary = await getListPage("glossary", "-index");
if (glossary.data.draft) {
  return Astro.redirect("/404");
}

const { title, description } = glossary.data;
const { Content } = await render(glossary);
---

<Base {...glossary.data}>
  <section class="section bg-light">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="pb-4" data-aos="fade-up-sm" set:html={markdownify(title)} />
        <p class="pb-8 text-balance" data-aos="fade-up-sm" data-aos-delay="100" set:html={markdownify(description)} />
      </div>
    </div>
  </section>

  <section class="section pb-0">
    <div class="container">
      <div class="row justify-center" data-aos="fade-up-sm" data-aos-delay="150">
        <div class="lg:col-10 xl:col-9">
          <article class="content glossary-content">
            <Content />
          </article>
        </div>
      </div>
    </div>
  </section>
</Base>
